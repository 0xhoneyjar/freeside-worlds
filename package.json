{
  "name": "freeside-worlds",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/0xHoneyJar/freeside-worlds.git"
  },
  "description": "META layer for worlds — creator + protocol + registry + docs. Authoring surface (COSMOGRAPHER apprenticeship) + sealed schemas + Terraform generator. The base scaffold lives at 0xHoneyJar/world-base (referenced, not embedded).",
  "workspaces": [
    "packages/protocol",
    "packages/registry",
    "packages/creator",
    "packages/config-protocol",
    "packages/config-engine",
    "packages/config-adapters",
    "packages/config-service"
  ],
  "scripts": {
    "validate": "bun packages/registry/bin/validate.ts",
    "generate-tf": "bun packages/registry/bin/generate-tf.ts",
    "sync-from-tf": "bun packages/registry/bin/sync-from-tf.ts",
    "config:migrate": "bun packages/config-adapters/src/migrate.ts",
    "config:serve": "bun packages/config-service/src/server.ts",
    "config:test": "bun test packages/config-engine packages/config-service"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
